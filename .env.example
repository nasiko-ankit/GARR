# === Required ===

# Postgres connection string. The Docker Compose stack in Step 4 will
# expose Postgres on 5432 with these credentials.
DATABASE_URL=postgresql://garr:garr@localhost:5432/garr

# Ed25519 private key, PEM format.
# Signing is not used until Session 2, so a blank value is acceptable
# for Session 1 boot — but the config loader will still require the
# variable to be present (non-empty) per CLAUDE.md §332–357. Set a
# placeholder like "session-2-will-generate" for now, or generate a
# real dev keypair:
#   openssl genpkey -algorithm Ed25519 -out dev-signing.pem
#   cat dev-signing.pem
# and paste the PEM as a single-line value with literal \n separators,
# or use a dotenv loader that handles multi-line quoted values.
SIGNING_PRIVATE_KEY=

# === Optional ===

PORT=3000
NODE_ENV=development
SIGNING_KEY_ID=garr-dev-2026
DB_MAX_CONNECTIONS=10
